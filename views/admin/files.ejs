<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>File Uploads - Siva Medicals Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .sidebar {
            background: #343a40;
            min-height: 100vh;
            color: white;
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,.75);
            padding: 12px 20px;
            margin: 5px 0;
            border-radius: 5px;
        }
        .sidebar .nav-link:hover, .sidebar .nav-link.active {
            color: white;
            background: #d4a843;
        }
        .sidebar .nav-link i {
            margin-right: 10px;
            width: 20px;
        }
        .upload-zone {
            border: 2px dashed #dee2e6;
            border-radius: 10px;
            padding: 40px;
            text-align: center;
            transition: all 0.3s ease;
            background: #f8f9fa;
        }
        .upload-zone:hover, .upload-zone.dragover {
            border-color: #d4a843;
            background: #fff3cd;
        }
        .file-item {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 10px;
            background: white;
            transition: box-shadow 0.3s ease;
        }
        .file-item:hover {
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .file-icon {
            font-size: 2rem;
            margin-right: 15px;
        }
        .file-size {
            color: #666;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-3 col-lg-2 px-0 sidebar">
                <div class="p-3">
                    <h5 class="text-center mb-4 d-flex align-items-center justify-content-center gap-2">
                        <img src="/images/Logo- Sivamedical.png" alt="Siva Medicals Logo" style="height:28px; width:auto;">
                        Siva Medicals
                    </h5>
                    <nav class="nav flex-column">
                        <a class="nav-link" href="/admin/dashboard">
                            <i class="fas fa-tachometer-alt"></i> Dashboard
                        </a>
                        <a class="nav-link" href="/admin/contacts">
                            <i class="fas fa-envelope"></i> Contact Forms
                        </a>
                        <a class="nav-link active" href="/admin/files">
                            <i class="fas fa-file-upload"></i> File Uploads
                        </a>
                        <a class="nav-link" href="/admin/whatsapp">
                            <i class="fab fa-whatsapp"></i> WhatsApp
                        </a>
                        <% if (user.role === 'super_admin') { %>
                        <a class="nav-link" href="/admin/users">
                            <i class="fas fa-users"></i> Users
                        </a>
                        <% } %>
                    </nav>
                </div>
                <div class="mt-auto p-3">
                    <form method="POST" action="/admin/logout" class="d-inline">
                        <button type="submit" class="btn btn-outline-light btn-sm w-100">
                            <i class="fas fa-sign-out-alt me-2"></i>Logout
                        </button>
                    </form>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-9 col-lg-10 px-4 py-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2><i class="fas fa-file-upload me-2"></i>File Uploads</h2>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                        <i class="fas fa-plus me-2"></i>Upload File
                    </button>
                </div>

                <!-- Upload Zone -->
                <div class="upload-zone mb-4" id="uploadZone">
                    <i class="fas fa-cloud-upload-alt fa-3x text-muted mb-3"></i>
                    <h5>Drag & Drop Files Here</h5>
                    <p class="text-muted">or click to browse (max 10MB)</p>
                    <input type="file" id="fileInput" multiple style="display: none;">
                    <button class="btn btn-outline-primary" onclick="document.getElementById('fileInput').click()">
                        <i class="fas fa-folder-open me-2"></i>Browse Files
                    </button>
                </div>

                <!-- Files List -->
                <div id="filesList">
                    <% if (files.length === 0) { %>
                        <div class="text-center py-5">
                            <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
                            <h4 class="text-muted">No files uploaded yet</h4>
                            <p class="text-muted">Upload files using the form above</p>
                        </div>
                    <% } else { %>
                        <% files.forEach(file => { %>
                            <div class="file-item d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <% if (file.mime_type.startsWith('image/')) { %>
                                        <i class="fas fa-image file-icon text-success"></i>
                                    <% } else if (file.mime_type === 'application/pdf') { %>
                                        <i class="fas fa-file-pdf file-icon text-danger"></i>
                                    <% } else if (file.mime_type.includes('document') || file.mime_type.includes('word')) { %>
                                        <i class="fas fa-file-word file-icon text-primary"></i>
                                    <% } else { %>
                                        <i class="fas fa-file file-icon text-secondary"></i>
                                    <% } %>
                                    <div>
                                        <h6 class="mb-1"><%= file.original_name %></h6>
                                        <small class="text-muted">
                                            Uploaded by <%= file.username || 'Unknown' %> on
                                            <%= new Date(file.uploaded_at).toLocaleString() %>
                                            <span class="file-size ms-2">
                                                (<%= (file.size / 1024).toFixed(1) %> KB)
                                            </span>
                                        </small>
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    <a href="/uploads/<%= file.filename %>" target="_blank" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="/uploads/<%= file.filename %>" download="<%= file.original_name %>" class="btn btn-sm btn-outline-success">
                                        <i class="fas fa-download"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteFile(<%= file.id %>, '<%= file.original_name %>')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </div>
                        <% }); %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Upload Modal -->
    <div class="modal fade" id="uploadModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Upload File</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="uploadForm" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="uploadFile" class="form-label">Select File</label>
                            <input type="file" class="form-control" id="uploadFile" name="file" required>
                            <div class="form-text">Maximum file size: 10MB</div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="uploadForm" class="btn btn-primary">Upload</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Drag and drop functionality
        const uploadZone = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');

        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            uploadZone.addEventListener(eventName, preventDefaults, false);
        });

        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }

        ['dragenter', 'dragover'].forEach(eventName => {
            uploadZone.addEventListener(eventName, highlight, false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            uploadZone.addEventListener(eventName, unhighlight, false);
        });

        function highlight(e) {
            uploadZone.classList.add('dragover');
        }

        function unhighlight(e) {
            uploadZone.classList.remove('dragover');
        }

        uploadZone.addEventListener('drop', handleDrop, false);

        function handleDrop(e) {
            const dt = e.dataTransfer;
            const files = dt.files;
            handleFiles(files);
        }

        fileInput.addEventListener('change', function(e) {
            handleFiles(e.target.files);
        });

        function handleFiles(files) {
            [...files].forEach(uploadFile);
        }

        async function uploadFile(file) {
            const formData = new FormData();
            formData.append('file', file);

            try {
                const response = await fetch('/admin/upload', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    alert('File uploaded successfully!');
                    location.reload();
                } else {
                    alert('Upload failed: ' + result.error);
                }
            } catch (error) {
                console.error('Upload error:', error);
                alert('Upload failed');
            }
        }

        // Form submission
        document.getElementById('uploadForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const formData = new FormData(this);

            try {
                const response = await fetch('/admin/upload', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('uploadModal')).hide();
                    alert('File uploaded successfully!');
                    location.reload();
                } else {
                    alert('Upload failed: ' + result.error);
                }
            } catch (error) {
                console.error('Upload error:', error);
                alert('Upload failed');
            }
        });

        // Delete file
        async function deleteFile(fileId, filename) {
            if (!confirm(`Are you sure you want to delete "${filename}"?`)) {
                return;
            }

            try {
                const response = await fetch(`/admin/files/${fileId}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    alert('File deleted successfully!');
                    location.reload();
                } else {
                    alert('Failed to delete file');
                }
            } catch (error) {
                console.error('Delete error:', error);
                alert('Error deleting file');
            }
        }
    </script>
</body>
</html>